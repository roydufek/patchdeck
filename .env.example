# Required: 32+ chars each
PATCHDECK_MASTER_KEY=replace-with-32plus-char-random-string
PATCHDECK_JWT_SECRET=replace-with-another-32plus-char-random-string

# Optional
PATCHDECK_SSH_TIMEOUT_SECONDS=20
PATCHDECK_APPRISE_TIMEOUT_SECONDS=10
# Override only if apprise binary is not in PATH.
# PATCHDECK_APPRISE_BIN=/usr/local/bin/apprise
# Default destination URL for notifications (UI value overrides this).
# PATCHDECK_APPRISE_URL=tgram://bot_token/chat_id
